{
  "name": "pi-web",
  "version": "0.1.0",
  "private": true,
  "description": "Local/Tailscale web UI for pi coding agent.",
  "type": "module",
  "scripts": {
    "dev": "PI_WEB_DEV=1 node --import tsx --watch server.ts",
    "build": "vite build",
    "start": "node --import tsx server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run typecheck && npm run test && npm run test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "lucide": "^1.14.0",
    "marked": "^15.0.12",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.10.1",
    "@types/ws": "^8.5.14",
    "vitest": "^4.1.5"
  }
}
